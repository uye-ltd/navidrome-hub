[
  {
    "id": "deploy",
    "execute-command": "${NAVIDROME_DEPLOY_DIR}/deploy.sh",
    "command-working-directory": "${NAVIDROME_DEPLOY_DIR}",
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": "${WEBHOOK_SECRET}",
        "parameter": {
          "source": "header",
          "name": "X-Hub-Signature-256"
        }
      }
    }
  }
]

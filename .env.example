# Host port where app is served (e.g. 127.0.0.1:4533)
NAVIDROME_HOST_PORT=127.0.0.1:4533
# Absolute path to your music library on the host
NAVIDROME_MUSIC_PATH=/path/to/music
# Absolute path to the cloned repo on the server
NAVIDROME_DEPLOY_DIR=/path/to/this/repo
# OS user that owns the repo and runs the deploy
NAVIDROME_DEPLOY_USER=<user>

# Navidrome secrets (passed as environment variables to the container)
# Passphrase to encrypt passwords in the DB; leave empty to disable encryption
ND_PASSWORDENCRYPTIONKEY=
# Last.fm API key for scrobbling and artist metadata
ND_LASTFM_APIKEY=
# Last.fm API secret
ND_LASTFM_SECRET=
# Basic Auth password for /metrics endpoint (user: navidrome); leave empty for no auth
ND_PROMETHEUS_PASSWORD=
# Path to TLS certificate file; leave empty to disable TLS
ND_TLSCERT=
# Path to TLS private key file; leave empty to disable TLS
ND_TLSKEY=

# Shared secret for GitHub webhook HMAC-SHA256 verification
WEBHOOK_SECRET=

NAVIDROME_HOST_PORT=4533                 # Host port where app is served
NAVIDROME_MUSIC_PATH=/path/to/music      # Absolute path to your music library on the host
NAVIDROME_DEPLOY_DIR=/path/to/this/repo  # Absolute path to the cloned repo on the server
NAVIDROME_DEPLOY_USER=<user>             # OS user that owns the repo and runs the deploy
WEBHOOK_SECRET=<your-secret>             # Secret shared with GitHub webhook

# Navidrome secrets (passed as environment variables to the container)
ND_PASSWORDENCRYPTIONKEY=                # Passphrase to encrypt passwords in the DB; leave empty to disable encryption
ND_LASTFM_APIKEY=                        # Last.fm API key for scrobbling and artist metadata
ND_LASTFM_SECRET=                        # Last.fm API secret
ND_PROMETHEUS_PASSWORD=                  # Basic Auth password for /metrics endpoint (user: navidrome); leave empty for no auth
ND_TLSCERT=                              # Path to TLS certificate file; leave empty to disable TLS
ND_TLSKEY=                               # Path to TLS private key file; leave empty to disable TLS